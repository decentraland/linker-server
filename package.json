{
  "name": "linker-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --trace-warnings --abort-on-uncaught-exception --unhandled-rejections=strict dist/index.js",
    "lint": "eslint '{src,test}/**/*.{js,ts}'",
    "lint:fix": "eslint '{src,test}/**/*.{js,ts}' --fix",
    "start:dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.502.0",
    "@dcl/core-commons": "^0.10.1",
    "@dcl/crypto": "^3.7.0",
    "@dcl/fetch-component": "^1.1.1",
    "@dcl/http-commons": "^2.0.0",
    "@dcl/http-requests-logger-component": "^1.0.0",
    "@dcl/http-server": "^2.1.0",
    "@dcl/http-tracer-component": "^2.0.1",
    "@dcl/job-component": "^0.3.5",
    "@dcl/memory-cache-component": "^2.4.3",
    "@dcl/metrics": "^1.0.1",
    "@dcl/schemas": "^15.1.0",
    "@dcl/tracer-component": "^1.0.0",
    "@well-known-components/env-config-provider": "^1.2.0",
    "@well-known-components/interfaces": "^1.5.2",
    "@well-known-components/logger": "^3.1.3",
    "ajv": "^8.12.0",
    "busboy": "^1.6.0",
    "dcl-catalyst-client": "^22.0.0",
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^2.3.1",
    "@dcl/test-helpers": "^0.2.0",
    "@types/busboy": "^1.5.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.2",
    "eslint": "^8",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "tabWidth": 2
  }
}
